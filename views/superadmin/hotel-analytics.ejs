<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= hotel.name %> Analytics | Super Admin</title>
  <%- include('../partials/admin-header') %>
</head>
<body class="fade-in">
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <%- include('../partials/admin-navbar') %>

  <div class="container-fluid px-4 mt-4">
    <div class="row">
      <%- include('../partials/superadmin-sidebar', { currentPage: 'analytics' }) %>

      <main class="col-md-10 py-2">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5 ps-3">
          <div>
            <a href="/superadmin/analytics" class="text-secondary small text-decoration-none mb-2 d-block">
              <i class="fas fa-arrow-left me-1"></i> Back to Network Analytics
            </a>
            <h1 class="display-6 mb-0"><%= hotel.name %></h1>
            <p class="text-secondary">Hotel analytics — managed by <span style="color:#68d391;"><%= hotel.adminId?.name %></span></p>
          </div>
          <div class="d-flex gap-2">
            <span class="badge px-3 py-2" style="background:rgba(16,185,129,0.15);color:#68d391;border:1px solid rgba(16,185,129,0.3);border-radius:20px;">
              <i class="fas fa-utensils me-1"></i> Food <%= hotel.modules.foodSystem ? 'ON' : 'OFF' %>
            </span>
            <span class="badge px-3 py-2" style="background:rgba(99,179,237,0.15);color:#63b3ed;border:1px solid rgba(99,179,237,0.3);border-radius:20px;">
              <i class="fas fa-bed me-1"></i> Rooms <%= hotel.modules.roomBooking ? 'ON' : 'OFF' %>
            </span>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="row g-4 mb-5 ps-3">
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-primary border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-primary"><i class="fas fa-hotel fa-lg"></i></div>
                <span class="badge glass text-primary">1 Hotel</span>
              </div>
              <h6 class="text-secondary small fw-bold">TOTAL ORDERS</h6>
              <h2 class="mb-0 display-6 fw-bold" style="color:#f1f5f9;"><%= totalOrders %></h2>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-success border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-success"><i class="fas fa-rupee-sign fa-lg"></i></div>
                <span class="badge glass text-success">Total Earnings</span>
              </div>
              <h6 class="text-secondary small fw-bold">TOTAL REVENUE</h6>
              <h2 class="mb-0 display-6 fw-bold" style="color:#f1f5f9;">₹<%= totalRevenue %></h2>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-info border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-info"><i class="fas fa-users fa-lg"></i></div>
                <span class="badge glass text-info">Unique Customers</span>
              </div>
              <h6 class="text-secondary small fw-bold">TOTAL USERS</h6>
              <h2 class="mb-0 display-6 fw-bold" style="color:#f1f5f9;"><%= totalUsers %></h2>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-warning border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-warning"><i class="fas fa-check-double fa-lg"></i></div>
                <span class="badge glass text-warning">Fulfilled</span>
              </div>
              <h6 class="text-secondary small fw-bold">COMPLETED ORDERS</h6>
              <h2 class="mb-0 display-6 fw-bold" style="color:#f1f5f9;"><%= statusData[4] %></h2>
            </div>
          </div>
        </div>

        <!-- Charts Row -->
        <div class="row g-4 mb-5 ps-3">
          <div class="col-md-8">
            <div class="glass-card p-4">
              <h5 class="fw-bold mb-4" style="color:#f1f5f9;">
                <i class="fas fa-chart-line text-info me-2"></i> Orders Growth
              </h5>
              <div style="height:300px;">
                <canvas id="ordersChart"></canvas>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="glass-card p-4">
              <h5 class="fw-bold mb-4" style="color:#f1f5f9;">
                <i class="fas fa-chart-pie text-warning me-2"></i> Status Distribution
              </h5>
              <div style="height:300px;">
                <canvas id="statusChart"></canvas>
              </div>
            </div>
          </div>
        </div>

        <!-- Top Items -->
        <div class="glass-card overflow-hidden ms-3 mb-5">
          <div class="p-4 border-bottom border-white border-opacity-10">
            <h5 class="fw-bold mb-0" style="color:#f1f5f9;">
              <i class="fas fa-fire text-warning me-2"></i> Top Selling Items
            </h5>
          </div>
          <div class="p-4">
            <% if (topItems.length === 0) { %>
              <p class="text-secondary text-center py-3">No orders yet</p>
            <% } %>
            <% topItems.forEach((item, idx) => { %>
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-3">
                  <span style="color:<%= idx===0?'#fbbf24':idx===1?'#94a3b8':'#cd7f32' %>;font-weight:700;font-size:1.1rem;">
                    <%= idx===0?'🥇':idx===1?'🥈':idx===2?'🥉':`#${idx+1}` %>
                  </span>
                  <span style="color:#e2e8f0;"><%= item.name %></span>
                </div>
                <div class="d-flex align-items-center gap-3">
                  <div class="progress" style="width:120px;height:6px;background:rgba(255,255,255,0.08);border-radius:10px;">
                    <div class="progress-bar" style="width:<%= Math.round((item.count/topItems[0].count)*100) %>%;background:linear-gradient(90deg,#63b3ed,#68d391);border-radius:10px;"></div>
                  </div>
                  <span style="color:#68d391;font-weight:700;min-width:60px;text-align:right;"><%= item.count %> orders</span>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
  <script>
    Chart.defaults.color = 'rgba(255,255,255,0.5)';
    Chart.defaults.font.family = 'Inter, sans-serif';

    new Chart(document.getElementById('ordersChart'), {
      type: 'line',
      data: {
        labels: <%- JSON.stringify(chartLabels) %>,
        datasets: [{
          label: 'Orders',
          data: <%- JSON.stringify(chartData) %>,
          borderColor: '#3b82f6',
          backgroundColor: 'rgba(59,130,246,0.1)',
          borderWidth: 3, tension: 0.4, fill: true,
          pointBackgroundColor: '#3b82f6', pointRadius: 4
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { grid: { color: 'rgba(255,255,255,0.05)' }, beginAtZero: true },
          x: { grid: { display: false } }
        }
      }
    });

    new Chart(document.getElementById('statusChart'), {
      type: 'doughnut',
      data: {
        labels: <%- JSON.stringify(statusLabels) %>,
        datasets: [{
          data: <%- JSON.stringify(statusData) %>,
          backgroundColor: ['#f59e0b','#06b6d4','#6366f1','#10b981','#3b82f6','#ef4444'],
          borderWidth: 0, hoverOffset: 15
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } } },
        cutout: '70%'
      }
    });
  </script>
</body>
</html>
