<!DOCTYPE html>
<html lang="en">
<head>
  <title>Network Analytics | Super Admin</title>
  <%- include('../partials/admin-header') %>
</head>
<body class="fade-in">
  <!-- Animated Background -->
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <%- include('../partials/admin-navbar') %>

  <div class="container-fluid px-4 mt-4">
    <div class="row">
      <!-- Sidebar -->
      <%- include('../partials/superadmin-sidebar', { currentPage: 'analytics' }) %>

      <!-- Main Content -->
      <main class="col-md-10 py-2">
        <div class="d-flex justify-content-between align-items-center mb-5 ps-3">
          <div>
            <h1 class="display-6">System Analytics</h1>
            <p class="text-secondary">Global metrics across all registered hotel nodes</p>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="row g-4 mb-5 ps-3">
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-primary border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-primary"><i class="fas fa-hotel fa-lg"></i></div>
                <span class="badge glass text-primary">+<%= totalHotels %> total</span>
              </div>
              <h6 class="text-secondary small fw-bold">TOTAL HOTELS</h6>
              <h2 class="text-white mb-0 display-6 fw-bold"><%= totalHotels %></h2>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-success border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-success"><i class="fas fa-shopping-bag fa-lg"></i></div>
                <span class="badge glass text-success">Active Orders</span>
              </div>
              <h6 class="text-secondary small fw-bold">TOTAL ORDERS</h6>
              <h2 class="text-white mb-0 display-6 fw-bold"><%= totalOrders %></h2>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-info border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-info"><i class="fas fa-users fa-lg"></i></div>
                <span class="badge glass text-info">Users Joined</span>
              </div>
              <h6 class="text-secondary small fw-bold">TOTAL USERS</h6>
              <h2 class="text-white mb-0 display-6 fw-bold"><%= totalUsers %></h2>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 border-start border-warning border-4 border-0 border-top-0 border-end-0 border-bottom-0">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="glass p-3 rounded-3 text-warning"><i class="fas fa-rupee-sign fa-lg"></i></div>
                <span class="badge glass text-warning">Total Earnings</span>
              </div>
              <h6 class="text-secondary small fw-bold">TOTAL REVENUE</h6>
              <h2 class="text-white mb-0 display-6 fw-bold">₹<%= totalRevenue %></h2>
            </div>
          </div>
        </div>

        <!-- Charts Row -->
        <div class="row g-4 mb-5 ps-3">
          <div class="col-md-8">
            <div class="glass-card p-4">
              <h5 class="text-white fw-bold mb-4"><i class="fas fa-chart-line text-info me-2"></i> Orders Growth</h5>
              <div style="height: 300px;">
                <canvas id="ordersChart"></canvas>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="glass-card p-4">
              <h5 class="text-white fw-bold mb-4"><i class="fas fa-chart-pie text-warning me-2"></i> Status Distribution</h5>
              <div style="height: 300px;">
                <canvas id="statusChart"></canvas>
              </div>
            </div>
          </div>
        </div>

        <!-- Performance Table -->
        <div class="glass-card overflow-hidden ps-0">
          <div class="p-4 border-bottom border-white border-opacity-10">
            <h5 class="text-white fw-bold mb-0"><i class="fas fa-star text-warning me-2"></i> Hotels Performance</h5>
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th class="ps-4">Hotel</th>
                  <th>Admin</th>
                  <th>Total Orders</th>
                  <th>Revenue</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% hotelStats.forEach(h => { %>
                  <tr>
                    <td class="ps-4">
                      <a href="/superadmin/hotel-analytics/<%= h.hotelId.toString() %>"
                        class="fw-bold text-decoration-none" style="color:#68d391;">
                        <%= h.name %>
                      </a>
                    </td>
                    <td style="color:#68d391;"><%= h.adminName %></td>
                    <td><span class="badge glass text-info px-3 py-2"><%= h.orderCount %></span></td>
                    <td class="text-success fw-bold">₹<%= h.revenue %></td>
                    <td>
                      <div class="d-flex gap-2">
                        <span class="badge glass <%= h.foodSystem ? 'text-success' : 'text-secondary' %> px-2 py-1 small">FOOD <%= h.foodSystem ? 'ON' : 'OFF' %></span>
                        <span class="badge glass <%= h.roomBooking ? 'text-info' : 'text-secondary' %> px-2 py-1 small">ROOM <%= h.roomBooking ? 'ON' : 'OFF' %></span>
                      </div>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
  <script>
    Chart.defaults.color = 'rgba(255, 255, 255, 0.5)';
    Chart.defaults.font.family = 'Inter, sans-serif';

    const ordersCtx = document.getElementById('ordersChart').getContext('2d');
    new Chart(ordersCtx, {
      type: 'line',
      data: {
        labels: <%- JSON.stringify(chartLabels) %>,
        datasets: [{
          label: 'Orders',
          data: <%- JSON.stringify(chartData) %>,
          borderColor: '#3b82f6',
          backgroundColor: 'rgba(59, 130, 246, 0.1)',
          borderWidth: 3, tension: 0.4, fill: true,
          pointBackgroundColor: '#3b82f6', pointRadius: 4
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { grid: { color: 'rgba(255,255,255,0.05)' }, beginAtZero: true },
          x: { grid: { display: false } }
        }
      }
    });

    const statusCtx = document.getElementById('statusChart').getContext('2d');
    new Chart(statusCtx, {
      type: 'doughnut',
      data: {
        labels: <%- JSON.stringify(statusLabels) %>,
        datasets: [{
          data: <%- JSON.stringify(statusData) %>,
          backgroundColor: ['#f59e0b','#06b6d4','#6366f1','#10b981','#3b82f6','#ef4444'],
          borderWidth: 0, hoverOffset: 15
        }]
      },
      options: {
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true } } },
        cutout: '70%'
      }
    });
  </script>
</body>
</html>
