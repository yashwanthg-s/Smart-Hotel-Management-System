<!DOCTYPE html>
<html lang="en">
<head>
  <title>Complaints & Refunds | Super Admin</title>
  <%- include('../partials/admin-header') %>
</head>
<body class="fade-in">
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
  <%- include('../partials/admin-navbar') %>

  <div class="container-fluid px-4 mt-4">
    <div class="row">
      <%- include('../partials/superadmin-sidebar', { currentPage: 'complaints' }) %>

      <main class="col-md-10 py-2">
        <div class="d-flex justify-content-between align-items-center mb-5 ps-3">
          <div>
            <h1 class="display-6">Complaints & Refunds</h1>
            <p class="text-secondary">Review complaints and process refunds</p>
          </div>
          <div class="d-flex gap-3">
            <div class="glass-card px-4 py-2 text-center">
              <div class="fw-bold fs-5" style="color:#fc8181;"><%= complaints.filter(c=>c.status==='open').length %></div>
              <div class="text-secondary small">Open</div>
            </div>
            <div class="glass-card px-4 py-2 text-center">
              <div class="fw-bold fs-5" style="color:#fbbf24;"><%= complaints.filter(c=>c.refundStatus==='pending').length %></div>
              <div class="text-secondary small">Refund Pending</div>
            </div>
            <div class="glass-card px-4 py-2 text-center">
              <div class="fw-bold fs-5" style="color:#68d391;"><%= complaints.filter(c=>c.status==='resolved').length %></div>
              <div class="text-secondary small">Resolved</div>
            </div>
          </div>
        </div>

        <!-- Filter Tabs -->
        <div class="d-flex gap-2 mb-4 ps-3">
          <button class="btn btn-gradient px-4" onclick="filterStatus('all',this)">All</button>
          <button class="btn btn-glass px-4" onclick="filterStatus('open',this)">Open</button>
          <button class="btn btn-glass px-4" onclick="filterStatus('in_review',this)">In Review</button>
          <button class="btn btn-glass px-4" onclick="filterStatus('resolved',this)">Resolved</button>
        </div>

        <div class="ps-3">
          <% if (complaints.length === 0) { %>
            <div class="glass-card p-5 text-center text-secondary">
              <i class="fas fa-check-circle fa-3x mb-3 d-block text-success opacity-50"></i>
              No complaints yet!
            </div>
          <% } %>

          <% complaints.forEach(c => { %>
            <div class="glass-card p-4 mb-3 complaint-row" data-status="<%= c.status %>"
              style="border-left:4px solid <%= c.status==='open'?'#fc8181':c.status==='in_review'?'#fbbf24':c.status==='resolved'?'#68d391':'#64748b' %>;">

              <!-- Header -->
              <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                  <span class="fw-bold" style="color:#68d391;"><%= c.userId?.name || 'Unknown' %></span>
                  <span class="text-secondary small ms-2"><%= c.userId?.email %></span>
                  <% if (c.hotelId) { %>
                    <span class="badge ms-2 px-2" style="background:rgba(99,179,237,0.15);color:#63b3ed;border-radius:20px;font-size:0.72rem;">
                      <i class="fas fa-hotel me-1"></i><%= c.hotelId.name %>
                    </span>
                  <% } %>
                  <span class="badge ms-2 px-2" style="background:rgba(251,191,36,0.15);color:#fbbf24;border-radius:20px;font-size:0.72rem;">
                    <%= c.category?.replace('_',' ').toUpperCase() %>
                  </span>
                </div>
                <div class="d-flex align-items-center gap-2">
                  <span class="badge px-3 py-2" style="border-radius:20px;font-size:0.75rem;
                    background:<%= c.status==='open'?'rgba(252,129,129,0.15)':c.status==='in_review'?'rgba(251,191,36,0.15)':'rgba(104,211,145,0.15)' %>;
                    color:<%= c.status==='open'?'#fc8181':c.status==='in_review'?'#fbbf24':'#68d391' %>;">
                    <%= c.status.replace('_',' ').toUpperCase() %>
                  </span>
                  <span class="text-secondary small"><%= new Date(c.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></span>
                </div>
              </div>

              <!-- Subject & Message -->
              <h6 class="fw-bold mb-1" style="color:#e2e8f0;"><%= c.subject %></h6>
              <p class="text-secondary mb-3" style="font-size:0.88rem;"><%= c.message %></p>

              <!-- Payment Info -->
              <% if (c.paymentInfo || c.orderInfo) { %>
                <div class="glass p-3 rounded-3 mb-3" style="border-left:3px solid #fbbf24;">
                  <div class="d-flex flex-wrap gap-3">
                    <% if (c.orderInfo) { %>
                      <div>
                        <span class="text-secondary small">Order:</span>
                        <span class="fw-bold ms-1" style="color:#e2e8f0;font-size:0.82rem;"><%= c.orderInfo.orderId %></span>
                      </div>
                    <% } %>
                    <% if (c.paymentInfo) { %>
                      <div>
                        <span class="text-secondary small">Paid:</span>
                        <span class="fw-bold ms-1" style="color:#fbbf24;">₹<%= c.paymentInfo.totalAmount %></span>
                      </div>
                      <div>
                        <span class="text-secondary small">Platform Fee (10%):</span>
                        <span class="fw-bold ms-1" style="color:#63b3ed;">₹<%= c.paymentInfo.platformFee %></span>
                      </div>
                      <div>
                        <span class="text-secondary small">Hotel Got:</span>
                        <span class="fw-bold ms-1" style="color:#68d391;">₹<%= c.paymentInfo.hotelAmount %></span>
                      </div>
                      <% if (c.paymentInfo.refundAmount > 0) { %>
                        <div>
                          <span class="text-secondary small">Refunded:</span>
                          <span class="fw-bold ms-1" style="color:#fc8181;">₹<%= c.paymentInfo.refundAmount %></span>
                        </div>
                      <% } %>
                    <% } else if (c.orderInfo) { %>
                      <div>
                        <span class="text-secondary small">Order Total:</span>
                        <span class="fw-bold ms-1" style="color:#fbbf24;">₹<%= c.orderInfo.totalPrice %></span>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% } %>

              <!-- Admin Reply -->
              <% if (c.adminReply) { %>
                <div class="glass p-3 rounded-3 mb-3" style="border-left:3px solid #68d391;">
                  <p class="small mb-0" style="color:#68d391;">
                    <i class="fas fa-reply me-1"></i> <strong>Admin Reply:</strong> <%= c.adminReply %>
                  </p>
                </div>
              <% } %>

              <!-- Refund Status -->
              <% if (c.refundStatus === 'approved') { %>
                <div class="badge px-3 py-2 mb-2" style="background:rgba(104,211,145,0.15);color:#68d391;border:1px solid rgba(104,211,145,0.3);border-radius:20px;">
                  ✅ Refund Approved — ₹<%= c.refundAmount %>
                </div>
              <% } else if (c.refundStatus === 'rejected') { %>
                <div class="badge px-3 py-2 mb-2" style="background:rgba(252,129,129,0.15);color:#fc8181;border:1px solid rgba(252,129,129,0.3);border-radius:20px;">
                  ❌ Refund Rejected
                </div>
              <% } %>

              <!-- Action Buttons -->
              <div class="d-flex gap-2 mt-2 flex-wrap">
                <% if (c.status !== 'resolved') { %>
                  <button class="btn btn-sm px-3" style="background:rgba(104,211,145,0.15);color:#68d391;border:1px solid rgba(104,211,145,0.3);border-radius:8px;"
                    onclick="openReply('<%= c._id %>')">
                    <i class="fas fa-reply me-1"></i> Reply & Resolve
                  </button>
                  <% if (c.status === 'open') { %>
                    <button class="btn btn-sm px-3" style="background:rgba(251,191,36,0.15);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);border-radius:8px;"
                      onclick="updateStatus('<%= c._id %>','in_review')">
                      <i class="fas fa-eye me-1"></i> Mark In Review
                    </button>
                  <% } %>
                <% } %>
                <% if (c.orderId && c.refundStatus === 'none' && c.status !== 'resolved') { %>
                  <button class="btn btn-sm px-3" style="background:rgba(252,129,129,0.15);color:#fc8181;border:1px solid rgba(252,129,129,0.3);border-radius:8px;"
                    onclick="openRefund('<%= c._id %>', <%= c.paymentInfo ? c.paymentInfo.totalAmount : (c.orderInfo ? c.orderInfo.totalPrice : 0) %>)">
                    <i class="fas fa-undo me-1"></i> Process Refund
                  </button>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      </main>
    </div>
  </div>

  <!-- Reply Modal -->
  <div class="modal fade" id="replyModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content glass-card overflow-hidden">
        <div class="modal-header bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-reply text-info me-2"></i> Reply to Complaint</h5>
          <button type="button" class="btn btn-glass p-2 border-0" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body p-4">
          <input type="hidden" id="replyComplaintId">
          <textarea class="form-control" id="replyText" rows="4" placeholder="Write your reply..."></textarea>
        </div>
        <div class="modal-footer bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
          <button type="button" class="btn btn-glass px-4" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-gradient px-4" onclick="submitReply()">
            <i class="fas fa-paper-plane me-2"></i> Send & Resolve
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Refund Modal -->
  <div class="modal fade" id="refundModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content glass-card overflow-hidden">
        <div class="modal-header bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-undo text-warning me-2"></i> Process Refund</h5>
          <button type="button" class="btn btn-glass p-2 border-0" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body p-4">
          <input type="hidden" id="refundComplaintId">
          <div class="mb-3">
            <label class="form-label text-secondary small fw-bold">REFUND AMOUNT (₹)</label>
            <input type="number" class="form-control" id="refundAmount" placeholder="Enter refund amount">
            <small class="text-secondary" id="refundMaxNote"></small>
          </div>
          <div class="mb-3">
            <label class="form-label text-secondary small fw-bold">REASON</label>
            <textarea class="form-control" id="refundReason" rows="3" placeholder="Reason for refund..."></textarea>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-gradient flex-grow-1" onclick="submitRefund('approve')">
              <i class="fas fa-check me-1"></i> Approve Refund
            </button>
            <button class="btn btn-glass px-4" style="color:#fc8181;" onclick="submitRefund('reject')">
              <i class="fas fa-times me-1"></i> Reject
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function filterStatus(status, btn) {
      document.querySelectorAll('.d-flex.gap-2 .btn').forEach(b => b.className = 'btn btn-glass px-4');
      btn.className = 'btn btn-gradient px-4';
      document.querySelectorAll('.complaint-row').forEach(row => {
        row.style.display = (status === 'all' || row.dataset.status === status) ? '' : 'none';
      });
    }

    function openReply(id) {
      document.getElementById('replyComplaintId').value = id;
      document.getElementById('replyText').value = '';
      new bootstrap.Modal(document.getElementById('replyModal')).show();
    }

    async function submitReply() {
      const id = document.getElementById('replyComplaintId').value;
      const reply = document.getElementById('replyText').value.trim();
      if (!reply) return;
      await fetch(`/api/complaints/${id}/reply`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reply })
      });
      location.reload();
    }

    async function updateStatus(id, status) {
      await fetch(`/api/complaints/${id}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      });
      location.reload();
    }

    function openRefund(id, maxAmount) {
      document.getElementById('refundComplaintId').value = id;
      document.getElementById('refundAmount').value = maxAmount;
      document.getElementById('refundAmount').max = maxAmount;
      document.getElementById('refundMaxNote').textContent = `Max refundable: ₹${maxAmount}`;
      new bootstrap.Modal(document.getElementById('refundModal')).show();
    }

    async function submitRefund(action) {
      const id = document.getElementById('refundComplaintId').value;
      const amount = document.getElementById('refundAmount').value;
      const reason = document.getElementById('refundReason').value;
      await fetch(`/api/complaints/${id}/refund`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, amount: parseFloat(amount), reason })
      });
      location.reload();
    }
  </script>
</body>
</html>
