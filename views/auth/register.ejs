<!DOCTYPE html>
<html lang="en">
<head>
  <title>Register | Smart Hotel</title>
  <%- include('../partials/admin-header') %>
</head>
<body class="fade-in">
  <!-- Animated Background -->
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="container container-fluid px-4 py-5">
    <div class="row justify-content-center align-items-center min-vh-100">
      <div class="col-md-6 col-lg-5">
        <div class="text-center mb-5">
           <i class="fas fa-user-plus fs-1 text-info mb-3"></i>
           <h2 class="display-6 fw-bold text-white">Join the Network</h2>
           <p class="text-secondary">Create your account to start your journey</p>
        </div>

        <div class="glass-card p-5">
          <% if (typeof error !== 'undefined') { %>
            <div class="alert glass text-danger border-danger border-opacity-25 mb-4" role="alert">
              <i class="fas fa-exclamation-circle me-2"></i> <%= error %>
            </div>
          <% } %>

          <form method="POST" action="/register">
            <div class="row g-4">
              <div class="col-md-12">
                <label class="form-label text-secondary small fw-bold">FULL NAME</label>
                <div class="input-group glass rounded-3">
                  <span class="input-group-text bg-transparent border-0 text-info px-3">
                    <i class="fas fa-user"></i>
                  </span>
                  <input type="text" class="form-control bg-transparent border-0 text-white ps-0" name="name" required placeholder="John Doe">
                </div>
              </div>

              <div class="col-md-6">
                <label class="form-label text-secondary small fw-bold">EMAIL</label>
                <div class="input-group glass rounded-3">
                  <span class="input-group-text bg-transparent border-0 text-info px-3">
                    <i class="fas fa-envelope"></i>
                  </span>
                  <input type="email" class="form-control bg-transparent border-0 text-white ps-0" name="email" required placeholder="john@example.com">
                </div>
              </div>

              <div class="col-md-6">
                <label class="form-label text-secondary small fw-bold">PHONE</label>
                <div class="input-group glass rounded-3">
                  <span class="input-group-text bg-transparent border-0 text-info px-3">
                    <i class="fas fa-phone"></i>
                  </span>
                  <input type="tel" class="form-control bg-transparent border-0 text-white ps-0" name="phone" placeholder="+1 (555) 000-0000">
                </div>
              </div>

              <div class="col-md-6">
                <label class="form-label text-secondary small fw-bold">PASSWORD</label>
                <div class="input-group glass rounded-3">
                  <span class="input-group-text bg-transparent border-0 text-info px-3">
                    <i class="fas fa-lock"></i>
                  </span>
                  <input type="password" class="form-control bg-transparent border-0 text-white ps-0" name="password" required placeholder="••••••••">
                </div>
              </div>

              <div class="col-md-6">
                <label class="form-label text-secondary small fw-bold">CONFIRM</label>
                <div class="input-group glass rounded-3">
                  <span class="input-group-text bg-transparent border-0 text-info px-3">
                    <i class="fas fa-check-double"></i>
                  </span>
                  <input type="password" class="form-control bg-transparent border-0 text-white ps-0" name="confirmPassword" required placeholder="••••••••">
                </div>
              </div>
            </div>

            <button type="submit" class="btn btn-gradient w-100 py-3 rounded-3 shadow-lg my-5">
              Create Account <i class="fas fa-arrow-right ms-2"></i>
            </button>
          </form>

          <p class="text-center text-secondary small mb-0">
            Already have an account? <a href="/login" class="text-info text-decoration-none fw-bold">Login here</a>
          </p>
        </div>
        
        <div class="text-center mt-4">
          <a href="/" class="text-secondary small text-decoration-none hover-white">
            <i class="fas fa-arrow-left me-1"></i> Back to Homepage
          </a>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
