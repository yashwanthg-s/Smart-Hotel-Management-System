<!DOCTYPE html>
<html lang="en">
<head>
  <title>Table Management | Smart Hotel</title>
  <%- include('../partials/admin-header') %>
  <style>
    /* Local overrides for table statuses */
    .status-available { background: linear-gradient(135deg, rgba(40, 167, 69, 0.1), rgba(40, 167, 69, 0.2)); border-left: 4px solid #28a745 !important; }
    .status-occupied  { background: linear-gradient(135deg, rgba(220, 53, 69, 0.1), rgba(220, 53, 69, 0.2)); border-left: 4px solid #dc3545 !important; }
    .status-reserved  { background: linear-gradient(135deg, rgba(255, 193, 7, 0.1), rgba(255, 193, 7, 0.2)); border-left: 4px solid #ffc107 !important; }
    .status-maintenance { background: linear-gradient(135deg, rgba(108, 117, 125, 0.1), rgba(108, 117, 125, 0.2)); border-left: 4px solid #6c757d !important; }
  </style>
</head>
<body class="fade-in">
  <!-- Animated Background -->
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <%- include('../partials/admin-navbar') %>

  <div class="container-fluid px-4 mt-4">
    <div class="row">
      <!-- Sidebar -->
      <%- include('../partials/admin-sidebar', { currentPage: 'tables' }) %>

      <!-- Main content -->
      <main class="col-md-10 py-2">
        <div class="d-flex justify-content-between align-items-center mb-5 ps-3">
          <div>
            <h1 class="display-6">Reservations</h1>
            <p class="text-secondary">Manage restaurant floor and table occupancy</p>
          </div>
          <button class="btn btn-gradient px-4" data-bs-toggle="modal" data-bs-target="#addTableModal">
            <i class="fas fa-plus me-2"></i> Add Table
          </button>
        </div>

        <!-- Stats Row -->
        <div class="row g-4 mb-5 ps-3">
          <div class="col-md-3">
            <div class="glass-card p-4 text-center border-success border-opacity-25">
              <h2 class="display-6 fw-bold text-success mb-1"><%= stats.available %></h2>
              <p class="text-secondary small mb-0">🟢 Available</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 text-center border-danger border-opacity-25">
              <h2 class="display-6 fw-bold text-danger mb-1"><%= stats.occupied %></h2>
              <p class="text-secondary small mb-0">🔴 Occupied</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 text-center border-warning border-opacity-25">
              <h2 class="display-6 fw-bold text-warning mb-1"><%= stats.reserved %></h2>
              <p class="text-secondary small mb-0">🟡 Reserved</p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="glass-card p-4 text-center border-white border-opacity-10">
              <h2 class="display-6 fw-bold text-white mb-1"><%= stats.total %></h2>
              <p class="text-secondary small mb-0">📊 Total Tables</p>
            </div>
          </div>
        </div>

        <!-- Tables Grid -->
        <div class="row g-4 ps-3">
          <% tables.forEach(table => { %>
            <div class="col-md-4 col-lg-3">
              <div class="glass-card status-<%= table.status %> h-100 p-3">
                <div class="d-flex justify-content-between align-items-start mb-3">
                  <div class="fs-2">
                    <% if (table.status === 'available') { %> 🪑
                    <% } else if (table.status === 'occupied') { %> 🍽
                    <% } else if (table.status === 'reserved') { %> 🔖
                    <% } else { %> 🔧 <% } %>
                  </div>
                  <span class="badge glass <%= 
                    table.status === 'available' ? 'text-success' :
                    table.status === 'occupied' ? 'text-danger' :
                    table.status === 'reserved' ? 'text-warning' : 'text-secondary' %>">
                    <%= table.status.toUpperCase() %>
                  </span>
                </div>

                <h5 class="fw-bold text-white mb-1">Table <%= table.tableNumber %></h5>
                <p class="small text-secondary mb-3">
                  <i class="fas fa-users me-1"></i> <%= table.capacity %> seats &bull; 
                  <i class="fas fa-location-dot me-1"></i> <%= table.location %>
                </p>

                <% if (table.currentOrderId) { %>
                  <div class="glass p-2 rounded-3 mb-3 border-danger border-opacity-25">
                    <p class="small text-danger mb-0">
                      <i class="fas fa-receipt me-1"></i> #<%= table.currentOrderId.orderId %>
                    </p>
                  </div>
                <% } %>

                <select class="form-select form-select-sm mb-3" onchange="updateStatus('<%= table._id %>', this.value)">
                  <option value="available" <%= table.status === 'available' ? 'selected' : '' %>>🟢 Available</option>
                  <option value="occupied"  <%= table.status === 'occupied'  ? 'selected' : '' %>>🔴 Occupied</option>
                  <option value="reserved"  <%= table.status === 'reserved'  ? 'selected' : '' %>>🟡 Reserved</option>
                  <option value="maintenance" <%= table.status === 'maintenance' ? 'selected' : '' %>>⚙️ Maintenance</option>
                </select>

                <div class="d-flex gap-2">
                  <button class="btn btn-glass btn-sm flex-grow-1 text-warning"
                    onclick="editTable('<%= table._id %>','<%= table.tableNumber %>',<%= table.capacity %>,'<%= table.location %>','<%= table.status %>')">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button class="btn btn-glass btn-sm flex-grow-1 text-danger"
                    onclick="confirmDelete('<%= table._id %>','<%= table.tableNumber %>')">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </main>
    </div>
  </div>

  <!-- Add Table Modal -->
  <div class="modal fade" id="addTableModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content glass-card overflow-hidden">
        <div class="modal-header bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-plus text-info me-2"></i> Add Table</h5>
          <button type="button" class="btn btn-glass p-2 border-0" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
        </div>
        <form method="POST" action="/admin/tables">
          <div class="modal-body p-4">
            <div class="mb-3">
              <label class="form-label text-secondary small">Table Number / Name</label>
              <input type="text" class="form-control" name="tableNumber" placeholder="e.g. T1, VIP-1" required>
            </div>
            <div class="mb-3">
              <label class="form-label text-secondary small">Seating Capacity</label>
              <input type="number" class="form-control" name="capacity" min="1" max="20" placeholder="e.g. 4" required>
            </div>
            <div class="mb-0">
              <label class="form-label text-secondary small">Location</label>
              <select class="form-select" name="location">
                <option value="indoor">🏠 Indoor</option>
                <option value="outdoor">🌿 Outdoor</option>
                <option value="rooftop">🌆 Rooftop</option>
                <option value="private">🔒 Private</option>
              </select>
            </div>
          </div>
          <div class="modal-footer bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
            <button type="button" class="btn btn-glass px-4" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-gradient px-4">Add Table</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Table Modal -->
  <div class="modal fade" id="editTableModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content glass-card overflow-hidden">
        <div class="modal-header bg-warning bg-opacity-25 border-white border-opacity-10 p-4">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-edit text-warning me-2"></i> Edit Table</h5>
          <button type="button" class="btn btn-glass p-2 border-0" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
        </div>
        <form id="editTableForm" method="POST">
          <div class="modal-body p-4">
            <div class="mb-3">
              <label class="form-label text-secondary small">Table Number</label>
              <input type="text" class="form-control" name="tableNumber" id="editTableNumber" required>
            </div>
            <div class="mb-3">
              <label class="form-label text-secondary small">Capacity</label>
              <input type="number" class="form-control" name="capacity" id="editCapacity" min="1" max="20" required>
            </div>
            <div class="mb-3">
              <label class="form-label text-secondary small">Location</label>
              <select class="form-select" name="location" id="editLocation">
                <option value="indoor">🏠 Indoor</option>
                <option value="outdoor">🌿 Outdoor</option>
                <option value="rooftop">🌆 Rooftop</option>
                <option value="private">🔒 Private</option>
              </select>
            </div>
            <div class="mb-0">
              <label class="form-label text-secondary small">Status</label>
              <select class="form-select" name="status" id="editStatus">
                <option value="available">🟢 Available</option>
                <option value="occupied" >🔴 Occupied</option>
                <option value="reserved" >🟡 Reserved</option>
                <option value="maintenance">⚙️ Maintenance</option>
              </select>
            </div>
          </div>
          <div class="modal-footer bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
            <button type="button" class="btn btn-glass px-4" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-gradient px-4">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function updateStatus(tableId, status) {
      fetch(`/admin/tables/${tableId}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      })
      .then(res => res.json())
      .then(data => { if (data.success) location.reload(); })
      .catch(err => console.error(err));
    }

    function editTable(id, number, capacity, location, status) {
      document.getElementById('editTableNumber').value = number;
      document.getElementById('editCapacity').value = capacity;
      document.getElementById('editLocation').value = location;
      document.getElementById('editStatus').value = status;
      document.getElementById('editTableForm').action = `/admin/tables/${id}`;
      new bootstrap.Modal(document.getElementById('editTableModal')).show();
    }

    function confirmDelete(id, number) {
      if(confirm(`Delete Table ${number}?`)) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/admin/tables/${id}/delete`;
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
</body>
</html>
