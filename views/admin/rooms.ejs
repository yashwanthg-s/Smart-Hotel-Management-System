<!DOCTYPE html>
<html lang="en">
<head>
  <title>Room Management | Smart Hotel</title>
  <%- include('../partials/admin-header') %>
</head>
<body class="fade-in">
  <!-- Animated Background -->
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <%- include('../partials/admin-navbar') %>

  <div class="container-fluid px-4 mt-4">
    <div class="row">
      <!-- Sidebar -->
      <%- include('../partials/admin-sidebar', { currentPage: 'rooms' }) %>

      <!-- Main content -->
      <main class="col-md-10 py-2">
        <div class="d-flex justify-content-between align-items-center mb-5 ps-3">
          <div>
            <h1 class="display-6">Room Status</h1>
            <p class="text-secondary">Monitor and manage hotel room availability</p>
          </div>
          <button class="btn btn-gradient px-4" data-bs-toggle="modal" data-bs-target="#addRoomModal">
            <i class="fas fa-plus me-2"></i> Add Room
          </button>
        </div>

        <!-- Rooms Grid -->
        <div class="row g-4 ps-3">
          <% rooms.forEach(room => { %>
            <div class="col-md-6 col-lg-4">
              <div class="glass-card h-100">
                <% if (room.images && room.images.length > 0) { %>
                  <img src="<%= room.images[0] %>" class="card-img-top" alt="<%= room.roomNumber %>" style="height: 200px; object-fit: cover; opacity: 0.8;">
                <% } else { %>
                  <div class="card-img-top bg-dark bg-opacity-50 d-flex align-items-center justify-content-center" style="height: 200px;">
                    <i class="fas fa-bed fa-3x text-white-50"></i>
                  </div>
                <% } %>
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="fw-bold text-white mb-0">Room <%= room.roomNumber %></h5>
                    <span class="badge glass text-info px-3 py-2"><%= room.roomType %></span>
                  </div>
                  <div class="mb-4">
                    <p class="mb-2 text-secondary small"><i class="fas fa-tag me-2"></i>₹<%= room.price %>/night</p>
                    <p class="mb-2 text-secondary small"><i class="fas fa-users me-2"></i>Capacity: <%= room.capacity %> guests</p>
                    <p class="mb-0 text-white-50 small"><%= room.description %></p>
                  </div>
                  <div class="d-flex gap-2">
                    <button class="btn btn-glass btn-sm flex-grow-1 text-warning" onclick="editRoom('<%= room._id %>')">
                      <i class="fas fa-edit me-1"></i> Edit
                    </button>
                    <form method="POST" action="/admin/rooms/<%= room._id %>/delete" style="display:inline; flex-grow: 1;">
                      <button type="submit" class="btn btn-glass btn-sm w-100 text-danger" onclick="return confirm('Delete this room?')">
                        <i class="fas fa-trash me-1"></i> Delete
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </main>
    </div>
  </div>

  <!-- Add Room Modal -->
  <div class="modal fade" id="addRoomModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content glass-card overflow-hidden">
        <div class="modal-header bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-plus text-info me-2"></i> Add New Room</h5>
          <button type="button" class="btn btn-glass p-2 border-0" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
        </div>
        <form method="POST" action="/admin/rooms" enctype="multipart/form-data">
          <div class="modal-body p-4">
            <div class="row g-3">
              <div class="col-md-6 mb-3">
                <label for="roomNumber" class="form-label text-secondary small">Room Number</label>
                <input type="text" class="form-control" id="roomNumber" name="roomNumber" required placeholder="e.g. 101">
              </div>
              <div class="col-md-6 mb-3">
                <label for="roomType" class="form-label text-secondary small">Room Type</label>
                <select class="form-select" id="roomType" name="roomType" required>
                  <option value="single">Single</option>
                  <option value="double">Double</option>
                  <option value="suite">Suite</option>
                  <option value="deluxe">Deluxe</option>
                </select>
              </div>
            </div>
            <div class="row g-3">
              <div class="col-md-6 mb-3">
                <label for="price" class="form-label text-secondary small">Price per Night (₹)</label>
                <input type="number" class="form-control" id="price" name="price" step="0.01" required placeholder="0.00">
              </div>
              <div class="col-md-6 mb-3">
                <label for="capacity" class="form-label text-secondary small">Capacity (guests)</label>
                <input type="number" class="form-control" id="capacity" name="capacity" required value="2">
              </div>
            </div>
            <div class="mb-3">
              <label for="description" class="form-label text-secondary small">Description</label>
              <textarea class="form-control" id="description" name="description" rows="3" placeholder="Describe the room amenities..."></textarea>
            </div>
            <div class="mb-3">
              <label for="amenities" class="form-label text-secondary small">Amenities (comma-separated)</label>
              <input type="text" class="form-control" id="amenities" name="amenities" placeholder="WiFi, AC, TV, Mini Bar">
            </div>
            <div class="mb-0">
              <label for="images" class="form-label text-secondary small">Room Images (up to 5)</label>
              <input type="file" class="form-control" id="images" name="images" multiple accept="image/*">
            </div>
          </div>
          <div class="modal-footer bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
            <button type="button" class="btn btn-glass px-4" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-gradient px-4">Create Room</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
