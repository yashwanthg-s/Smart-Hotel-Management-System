<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Hotel | Premium Hospitality</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">

  <style>
    .hero-section {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .hero-content {
      position: relative;
      z-index: 10;
    }
    .feature-icon {
      width: 60px;
      height: 60px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 20px;
      background: rgba(255, 255, 255, 0.1);
      transition: var(--transition);
    }
    .feature-card:hover .feature-icon {
      transform: scale(1.1) rotate(5deg);
      background: var(--accent-blue);
      color: white;
    }
  </style>
</head>
<body class="fade-in">
  <!-- Animated Background -->
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center gap-2" href="/">
        <i class="fas fa-hotel fs-3 text-info"></i> 
        <span>SMART HOTEL</span>
      </a>
      <div class="ms-auto d-flex gap-2">
        <a href="/login" class="btn btn-glass px-4">Login</a>
        <a href="/register" class="btn btn-gradient px-4">Register</a>
      </div>
    </div>
  </nav>

  <section class="hero-section">
    <div class="container text-center hero-content">
      <span class="badge glass text-info mb-3 px-3 py-2 border-info border-opacity-25">NEXT GEN HOSPITALITY</span>
      <h1 class="display-3 fw-bold mb-4">Elevate Your Stay with <br><span class="text-info">Intelligent Management</span></h1>
      <p class="lead mb-5 text-secondary mx-auto" style="max-width: 700px;">
        A seamless fusion of fast-casual dining, premium room booking, and real-time operational analytics designed for the modern hotel.
      </p>
      <div class="d-flex flex-wrap gap-3 justify-content-center">
        <a href="/login" class="btn btn-gradient btn-lg px-5 py-3 rounded-4 shadow-lg">
          <i class="fas fa-rocket me-2"></i> Get Started
        </a>
        <a href="#features" class="btn btn-base btn-glass btn-lg px-5 py-3 rounded-4">
          Explore Features
        </a>
      </div>
    </div>
  </section>

  <section id="features" class="features py-5 mt-5">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="display-5 fw-bold mb-3">Our Core Ecosystem</h2>
        <p class="text-secondary mb-0">Modules designed to work in perfect harmony</p>
      </div>

      <div class="row g-4">
        <div class="col-md-6 col-lg-3">
          <div class="glass-card p-4 text-center h-100 feature-card">
            <div class="feature-icon text-info">
              <i class="fas fa-utensils"></i>
            </div>
            <h5 class="fw-bold mb-3">Food Ordering</h5>
            <p class="text-secondary small">Real-time menu browsing with live preparation tracking and seamless payments.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="glass-card p-4 text-center h-100 feature-card">
            <div class="feature-icon text-success">
              <i class="fas fa-bed"></i>
            </div>
            <h5 class="fw-bold mb-3">Room Booking</h5>
            <p class="text-secondary small">Visual inventory management with instant booking and multi-room availability.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="glass-card p-4 text-center h-100 feature-card">
            <div class="feature-icon text-warning">
              <i class="fas fa-qrcode"></i>
            </div>
            <h5 class="fw-bold mb-3">QR Verification</h5>
            <p class="text-secondary small">Military-grade digital verification system for orders and guest authentication.</p>
          </div>
        </div>
        <div class="col-md-6 col-lg-3">
          <div class="glass-card p-4 text-center h-100 feature-card">
            <div class="feature-icon text-purple" style="color:var(--accent-purple)">
              <i class="fas fa-chart-line"></i>
            </div>
            <h5 class="fw-bold mb-3">Admin Intelligence</h5>
            <p class="text-secondary small">Comprehensive dashboards offering live metrics on revenue and staff performance.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="mt-5 py-5 text-center">
    <div class="container">
      <div class="glass-card p-5 border-0 rounded-5">
        <h3 class="fw-bold mb-4 text-white">Ready to modernize your hotel?</h3>
        <p class="text-secondary mb-5">Join 500+ hotels already using our smart management platform.</p>
        <div class="d-flex justify-content-center gap-4 mb-5">
          <a href="/register" class="btn btn-gradient px-5 py-3 rounded-pill">Create Free Account</a>
          <a href="/login" class="btn btn-glass px-5 py-3 rounded-pill">Sign In</a>
        </div>
        <hr class="border-white border-opacity-10 mb-5">
        <p class="mb-0 text-white-50 small">&copy; 2024 <span class="text-white fw-bold">Smart Hotel Management</span>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
