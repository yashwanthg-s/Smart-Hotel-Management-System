<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Smart Hotel Management' %></title>
  
  <!-- Fonts & Icons -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
</head>
<body class="fade-in">
  <!-- Animated Background -->
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <% if (user) { %>
    <nav class="navbar navbar-expand-lg sticky-top">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/dashboard">
          <i class="fas fa-hotel fs-4"></i> 
          <span>SMART HOTEL</span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <i class="fas fa-bars text-white"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <li class="nav-item">
              <a class="nav-link active" href="/dashboard">
                <i class="fas fa-th-large me-1"></i> Dashboard
              </a>
            </li>
            <li class="nav-item">
              <span class="nav-link text-white-50 px-3">
                <i class="fas fa-user-circle me-1 text-info"></i> <%= user.name %>
              </span>
            </li>
            <li class="nav-item pt-2 pt-lg-0">
              <a class="btn btn-glass px-4" href="/logout">
                <i class="fas fa-sign-out-alt me-1"></i> Logout
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  <% } %>

  <main class="container py-4">
    <%- body %>
  </main>

  <footer class="mt-auto py-5 text-center">
    <div class="container">
      <div class="glass-card p-4 border-0">
        <p class="mb-0 text-secondary">&copy; 2024 <span class="text-white fw-bold">Smart Hotel Management</span>. All rights reserved.</p>
        <div class="mt-3 d-flex justify-content-center gap-3">
          <i class="fab fa-facebook text-secondary fs-5 cursor-pointer"></i>
          <i class="fab fa-twitter text-secondary fs-5 cursor-pointer"></i>
          <i class="fab fa-instagram text-secondary fs-5 cursor-pointer"></i>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
