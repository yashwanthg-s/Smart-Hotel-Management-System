<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container-fluid px-4">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/user/dashboard">
      <i class="fas fa-hotel fs-4 text-info"></i>
      <span>Smart Hotel</span>
    </a>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto align-items-center">
        <!-- Notification Bell -->
        <li class="nav-item me-2">
          <div class="position-relative" style="cursor:pointer;" onclick="toggleNotifications()">
            <i class="fas fa-bell fs-5 text-white-50" id="bellIcon"></i>
            <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
              style="font-size:0.6rem;display:none;">0</span>
          </div>
          <!-- Notification Dropdown -->
          <div id="notifDropdown" style="display:none;position:absolute;right:80px;top:56px;width:340px;z-index:9999;"
            class="glass-card p-0 overflow-hidden">
            <div class="p-3 border-bottom border-white border-opacity-10 d-flex justify-content-between align-items-center">
              <span class="fw-bold text-white small">Notifications</span>
              <button onclick="markAllRead()" class="btn btn-glass btn-sm px-2 py-1" style="font-size:0.72rem;">
                Mark all read
              </button>
            </div>
            <div id="notifList" style="max-height:320px;overflow-y:auto;">
              <div class="text-center text-secondary py-4 small">Loading...</div>
            </div>
          </div>
        </li>
        <li class="nav-item">
          <span class="nav-link text-white-50 px-3">
            <i class="fas fa-user-circle me-1 text-info"></i> <%= user.name %>
          </span>
        </li>
        <li class="nav-item">
          <a class="btn btn-glass px-4" href="/logout">Logout</a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  let notifOpen = false;

  async function loadNotifications() {
    try {
      const res = await fetch('/api/notifications');
      const data = await res.json();
      const list = document.getElementById('notifList');
      const badge = document.getElementById('notifBadge');
      const bell = document.getElementById('bellIcon');

      const unread = data.filter(n => !n.read).length;
      if (unread > 0) {
        badge.textContent = unread;
        badge.style.display = '';
        bell.className = 'fas fa-bell fs-5 text-warning';
      } else {
        badge.style.display = 'none';
        bell.className = 'fas fa-bell fs-5 text-white-50';
      }

      if (data.length === 0) {
        list.innerHTML = '<div class="text-center text-secondary py-4 small"><i class="fas fa-check-circle d-block mb-2 text-success opacity-50 fs-4"></i>No notifications</div>';
        return;
      }

      list.innerHTML = data.map(n => `
        <div class="p-3 d-flex gap-3 align-items-start notif-item ${n.read ? '' : 'unread-notif'}"
          style="border-bottom:1px solid rgba(255,255,255,0.06);cursor:pointer;background:${n.read ? 'transparent' : 'rgba(99,179,237,0.06)'};"
          onclick="markRead('${n._id}')">
          <div class="flex-shrink-0 mt-1">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
              style="width:34px;height:34px;background:${n.type==='refund_approved'?'rgba(104,211,145,0.2)':n.type==='refund_rejected'?'rgba(252,129,129,0.2)':'rgba(99,179,237,0.2)'};">
              <i class="fas fa-${n.type==='refund_approved'?'check-circle text-success':n.type==='refund_rejected'?'times-circle text-danger':'reply text-info'}" style="font-size:0.85rem;"></i>
            </div>
          </div>
          <div style="flex:1;">
            <p class="mb-0 fw-bold" style="color:#e2e8f0;font-size:0.85rem;">${n.title}</p>
            <p class="mb-0 text-secondary" style="font-size:0.78rem;">${n.message}</p>
            <p class="mb-0 text-secondary" style="font-size:0.7rem;margin-top:3px;">${new Date(n.createdAt).toLocaleString('en-IN',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</p>
          </div>
          ${!n.read ? '<div class="flex-shrink-0"><div style="width:8px;height:8px;border-radius:50%;background:#63b3ed;margin-top:6px;"></div></div>' : ''}
        </div>
      `).join('');
    } catch (e) { console.error(e); }
  }

  function toggleNotifications() {
    notifOpen = !notifOpen;
    document.getElementById('notifDropdown').style.display = notifOpen ? 'block' : 'none';
    if (notifOpen) loadNotifications();
  }

  async function markRead(id) {
    await fetch(`/api/notifications/${id}/read`, { method: 'PUT' });
    loadNotifications();
  }

  async function markAllRead() {
    await fetch('/api/notifications/read-all', { method: 'PUT' });
    loadNotifications();
  }

  // Close on outside click
  document.addEventListener('click', function(e) {
    if (!e.target.closest('#notifDropdown') && !e.target.closest('.fa-bell') && notifOpen) {
      notifOpen = false;
      document.getElementById('notifDropdown').style.display = 'none';
    }
  });

  // Load badge count on page load
  loadNotifications();
  // Poll every 30 seconds
  setInterval(loadNotifications, 30000);
</script>
