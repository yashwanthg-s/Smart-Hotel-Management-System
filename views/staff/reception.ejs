<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reception Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body { background: #f5f5f5; }
    .top-nav { background: #1a3a6b; }
    .req-card { border-radius: 12px; border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .status-pending { border-left: 4px solid #dc3545; }
    .status-in_progress { border-left: 4px solid #17a2b8; }
    .status-done { border-left: 4px solid #28a745; opacity: 0.7; }
    .pulse { animation: pulse 1s infinite; color: #dc3545; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  </style>
</head>
<body>
  <nav class="navbar top-nav navbar-dark sticky-top">
    <div class="container-fluid">
      <span class="navbar-brand"><i class="fas fa-concierge-bell"></i> Reception</span>
      <span class="navbar-text text-white small">👤 <%= user.name %></span>
      <a href="/logout" class="btn btn-sm btn-outline-light">Logout</a>
    </div>
  </nav>

  <div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h4 class="mb-0"><i class="fas fa-receipt"></i> Bill Requests</h4>
        <small class="text-muted">Handle customer billing</small>
      </div>
      <button class="btn btn-sm btn-outline-dark" onclick="loadRequests()">
        <i class="fas fa-sync-alt"></i> Refresh
      </button>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
      <div class="col-4">
        <div class="card text-center border-0 bg-danger text-white" style="border-radius:10px;">
          <div class="card-body py-2">
            <div class="fs-3 fw-bold" id="pendingCount">0</div>
            <div class="small">Pending Bills</div>
          </div>
        </div>
      </div>
      <div class="col-4">
        <div class="card text-center border-0 bg-info text-white" style="border-radius:10px;">
          <div class="card-body py-2">
            <div class="fs-3 fw-bold" id="inProgressCount">0</div>
            <div class="small">Processing</div>
          </div>
        </div>
      </div>
      <div class="col-4">
        <div class="card text-center border-0 bg-success text-white" style="border-radius:10px;">
          <div class="card-body py-2">
            <div class="fs-3 fw-bold" id="doneCount">0</div>
            <div class="small">Settled Today</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bill Requests -->
    <div id="requestsList">
      <div class="text-center py-5 text-muted">
        <i class="fas fa-spinner fa-spin fa-2x mb-3 d-block"></i>
        Loading bill requests...
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const hotelId = '<%= hotelId %>';

    async function loadRequests() {
      try {
        const res = await fetch(`/api/service-requests?hotelId=${hotelId}`);
        const data = await res.json();
        const doneRes = await fetch(`/api/service-requests/done?hotelId=${hotelId}`);
        const doneData = await doneRes.json();

        const pending = data.filter(r => r.status === 'pending');
        const inProgress = data.filter(r => r.status === 'in_progress');

        document.getElementById('pendingCount').textContent = pending.length;
        document.getElementById('inProgressCount').textContent = inProgress.length;
        document.getElementById('doneCount').textContent = doneData.length;

        const list = document.getElementById('requestsList');
        const allRequests = [...data, ...doneData];

        if (!allRequests.length) {
          list.innerHTML = `<div class="text-center py-5 text-muted">
            <i class="fas fa-check-circle fa-3x mb-3 d-block text-success"></i>
            <p>No pending bill requests</p></div>`;
          return;
        }

        list.innerHTML = allRequests.map(r => `
          <div class="card req-card status-${r.status} mb-3">
            <div class="card-body p-3">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <h6 class="fw-bold mb-1">🧾 Bill Request</h6>
                  <p class="mb-1">
                    <span class="badge bg-dark fs-6"><i class="fas fa-chair"></i> Table ${r.tableNumber}</span>
                  </p>
                  ${r.customNote ? `<p class="text-muted small mb-1">"${r.customNote}"</p>` : ''}
                  <small class="text-muted">
                    <i class="fas fa-clock"></i>
                    ${new Date(r.createdAt).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'})}
                    ${r.status === 'pending' ? '<span class="pulse ms-2 fw-bold">● URGENT</span>' : ''}
                  </small>
                </div>
                <div class="d-flex flex-column gap-1 align-items-end">
                  <span class="badge bg-${r.status === 'pending' ? 'danger' : r.status === 'in_progress' ? 'info' : 'success'} fs-6">
                    ${r.status === 'pending' ? '⏳ Pending' : r.status === 'in_progress' ? '🔄 Processing' : '✅ Settled'}
                  </span>
                  ${r.status === 'pending' ? `
                    <button class="btn btn-sm btn-warning mt-1" onclick="updateReq('${r._id}','in_progress')">
                      <i class="fas fa-file-invoice"></i> Process Bill
                    </button>` : ''}
                  ${r.status === 'in_progress' ? `
                    <button class="btn btn-sm btn-success mt-1" onclick="updateReq('${r._id}','done')">
                      <i class="fas fa-check"></i> Bill Settled
                    </button>` : ''}
                </div>
              </div>
            </div>
          </div>`).join('');
      } catch (e) {
        console.error(e);
      }
    }

    async function updateReq(id, status) {
      await fetch(`/api/service-requests/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      });
      loadRequests();
    }

    loadRequests();
    setInterval(loadRequests, 10000); // Refresh every 10 seconds
  </script>
</body>
</html>
