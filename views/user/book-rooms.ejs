<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= hotel.name %> - Book Rooms</title>
  <%- include('../partials/admin-header') %>
  <style>
    body { background: #0f172a; }
    .top-nav { background: #1a1a2e; padding: 12px 20px; }
    .room-card { border-radius: 16px; border: none; overflow: hidden; transition: all 0.25s; cursor: pointer; }
    .room-card:hover { transform: translateY(-5px); box-shadow: 0 12px 30px rgba(0,0,0,0.3); }
    .room-img { width: 100%; height: 200px; object-fit: cover; }
    .room-img-placeholder { height: 160px; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; }
    .amenity-badge { background: rgba(99,179,237,0.1); color: #63b3ed; border: 1px solid rgba(99,179,237,0.2); border-radius: 20px; padding: 3px 10px; font-size: 0.75rem; }
  </style>
</head>
<body class="fade-in">
  <div class="bg-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <!-- Navbar -->
  <nav class="navbar top-nav navbar-dark sticky-top">
    <div class="container-fluid">
      <a href="/user/dashboard" class="text-white text-decoration-none">
        <i class="fas fa-arrow-left me-2"></i> Back
      </a>
      <span class="text-white fw-bold"><i class="fas fa-hotel me-2"></i><%= hotel.name %></span>
      <span class="text-white-50 small"><%= user.name %></span>
    </div>
  </nav>

  <!-- Hotel Banner -->
  <div style="background:linear-gradient(135deg,#1a1a2e,#16213e);padding:24px 20px;border-bottom:1px solid rgba(255,255,255,0.08);">
    <div class="container">
      <h3 class="fw-bold text-white mb-1"><%= hotel.name %></h3>
      <p class="text-secondary mb-0"><i class="fas fa-map-marker-alt me-1"></i><%= hotel.address %></p>
    </div>
  </div>

  <div class="container py-4">
    <!-- Date Picker -->
    <div class="glass-card p-4 mb-4">
      <h5 class="fw-bold text-white mb-3"><i class="fas fa-calendar-alt text-info me-2"></i> Select Your Dates</h5>
      <div class="row g-3 align-items-end">
        <div class="col-md-4">
          <label class="form-label text-secondary small">Check-in Date</label>
          <input type="date" class="form-control" id="checkInDate" onchange="updateSearch()">
        </div>
        <div class="col-md-4">
          <label class="form-label text-secondary small">Check-out Date</label>
          <input type="date" class="form-control" id="checkOutDate" onchange="updateSearch()">
        </div>
        <div class="col-md-4">
          <button class="btn btn-gradient w-100" onclick="searchAvailableRooms()">
            <i class="fas fa-search me-2"></i> Search Available Rooms
          </button>
        </div>
      </div>
      <div id="dateInfo" class="mt-2 text-secondary small"></div>
    </div>

    <!-- Search Bar -->
    <div class="mb-3" id="roomSearchBar" style="display:none;">
      <div class="input-group" style="max-width:380px;">
        <span class="input-group-text" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:#94a3b8;border-right:none;">
          <i class="fas fa-search"></i>
        </span>
        <input type="text" id="roomSearch" class="form-control"
          placeholder="Search rooms by name or type..."
          style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-left:none;color:#e2e8f0;"
          oninput="filterRooms(this.value)">
      </div>
    </div>

    <!-- Filter & Sort Options -->
    <div id="roomFilters" style="display:none;flex-wrap:wrap;gap:8px;margin-bottom:16px;align-items:center;">
      <span class="text-secondary small me-1">Sort by:</span>
      <button class="filter-btn active" id="filter-nearby" onclick="sortRooms('nearby', this)">
        <i class="fas fa-map-marker-alt me-1"></i> Nearby
      </button>
      <button class="filter-btn" id="filter-rating" onclick="sortRooms('rating', this)">
        <i class="fas fa-star me-1"></i> Top Rated
      </button>
      <button class="filter-btn" id="filter-price-low" onclick="sortRooms('price-low', this)">
        <i class="fas fa-rupee-sign me-1"></i> Price: Low to High
      </button>
      <button class="filter-btn" id="filter-price-high" onclick="sortRooms('price-high', this)">
        <i class="fas fa-rupee-sign me-1"></i> Price: High to Low
      </button>
      <div class="ms-auto d-flex align-items-center gap-2">
        <span class="text-secondary small">Max ₹</span>
        <input type="number" id="maxPrice" class="form-control form-control-sm"
          placeholder="Any" style="width:90px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:#e2e8f0;"
          oninput="applyPriceFilter()">
      </div>
    </div>

    <style>
      .filter-btn {
        padding: 6px 16px; border-radius: 25px; font-size: 0.82rem; font-weight: 600;
        border: 1.5px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.05);
        color: #94a3b8; cursor: pointer; transition: all 0.2s;
      }
      .filter-btn:hover { border-color: rgba(99,179,237,0.5); color: #63b3ed; }
      .filter-btn.active { background: rgba(99,179,237,0.15); border-color: #63b3ed; color: #63b3ed; }
    </style>

    <!-- Rooms Grid -->
    <div id="roomsContainer">
      <div class="text-center text-secondary py-5">
        <i class="fas fa-calendar-alt fa-3x mb-3 d-block opacity-25"></i>
        <p>Select check-in and check-out dates to see available rooms</p>
      </div>
    </div>

    <!-- My Bookings for this Hotel -->
    <div class="mt-5 pt-4" style="border-top:1px solid rgba(255,255,255,0.08);">
      <h5 class="fw-bold text-white mb-4"><i class="fas fa-history text-info me-2"></i> My Bookings at <%= hotel.name %></h5>
      <div id="myHotelBookings">
        <div class="text-center text-secondary py-3">
          <i class="fas fa-spinner fa-spin me-2"></i> Loading your bookings...
        </div>
      </div>
    </div>
  </div>

  <!-- Booking Modal -->
  <div class="modal fade" id="bookingModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content glass-card overflow-hidden">
        <div class="modal-header bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
          <h5 class="modal-title fw-bold text-white"><i class="fas fa-bed text-info me-2"></i> Confirm Booking</h5>
          <button type="button" class="btn btn-glass p-2 border-0" data-bs-dismiss="modal"><i class="fas fa-times"></i></button>
        </div>
        <div class="modal-body p-4">
          <div id="bookingSummary" class="glass p-3 rounded-3 mb-4"></div>
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label text-secondary small">Guest Name *</label>
              <input type="text" class="form-control" id="guestName" placeholder="Full name" value="<%= user.name %>">
            </div>
            <div class="col-md-6">
              <label class="form-label text-secondary small">Phone *</label>
              <input type="tel" class="form-control" id="guestPhone" placeholder="Phone number" value="<%= user.phone || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label text-secondary small">Email</label>
              <input type="email" class="form-control" id="guestEmail" placeholder="Email" value="<%= user.email %>">
            </div>
            <div class="col-md-6">
              <label class="form-label text-secondary small">Number of Guests</label>
              <input type="number" class="form-control" id="numGuests" value="1" min="1" max="10">
            </div>
            <div class="col-12">
              <label class="form-label text-secondary small">Special Requests</label>
              <textarea class="form-control" id="specialReq" rows="2" placeholder="Any special requests..."></textarea>
            </div>
          </div>
          <div id="bookingMsg" class="mt-3"></div>
        </div>
        <div class="modal-footer bg-dark bg-opacity-50 border-white border-opacity-10 p-4">
          <button type="button" class="btn btn-glass px-4" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-gradient px-4" id="confirmBookBtn" onclick="confirmBooking()">
            <i class="fas fa-check me-2"></i> Confirm Booking
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/eta.js"></script>
  <script>
    const hotelId = '<%= hotel._id %>';
    const hotelLat = <%= hotel.latitude %>;
    const hotelLng = <%= hotel.longitude %>;
    let allRooms = [];
    let selectedRoom = null;
    let checkIn = '', checkOut = '';

    // Set min date to today
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('checkInDate').min = today;
    document.getElementById('checkOutDate').min = today;

    document.getElementById('checkInDate').addEventListener('change', function() {
      document.getElementById('checkOutDate').min = this.value;
    });

    function updateSearch() {
      checkIn = document.getElementById('checkInDate').value;
      checkOut = document.getElementById('checkOutDate').value;
      if (checkIn && checkOut) {
        const nights = Math.ceil((new Date(checkOut) - new Date(checkIn)) / (1000*60*60*24));
        if (nights > 0) {
          document.getElementById('dateInfo').innerHTML =
            `<i class="fas fa-moon text-info me-1"></i> ${nights} night${nights>1?'s':''} selected`;
        }
      }
    }

    async function searchAvailableRooms() {
      checkIn = document.getElementById('checkInDate').value;
      checkOut = document.getElementById('checkOutDate').value;

      if (!checkIn || !checkOut) {
        document.getElementById('roomsContainer').innerHTML =
          '<div class="text-center text-warning py-4"><i class="fas fa-exclamation-triangle me-2"></i>Please select both check-in and check-out dates</div>';
        return;
      }

      const nights = Math.ceil((new Date(checkOut) - new Date(checkIn)) / (1000*60*60*24));
      if (nights <= 0) {
        document.getElementById('roomsContainer').innerHTML =
          '<div class="text-center text-warning py-4">Check-out must be after check-in</div>';
        return;
      }

      document.getElementById('roomsContainer').innerHTML =
        '<div class="text-center text-secondary py-4"><i class="fas fa-spinner fa-spin me-2"></i>Searching available rooms...</div>';

      try {
        const res = await fetch(`/api/hotels/${hotelId}/rooms?checkInDate=${checkIn}&checkOutDate=${checkOut}`);
        allRooms = await res.json();
        renderRooms(allRooms, nights);

        // Show search and filters only after rooms load
        if (allRooms.length > 0) {
          document.getElementById('roomSearchBar').style.display = 'block';
          document.getElementById('roomFilters').style.display = 'flex';
        }

        // Load ETA
        ETAModule.init().then(granted => {
          if (granted) {
            ETAModule.fetchETA(hotelLat, hotelLng).then(etaData => {
              if (etaData) {
                document.querySelectorAll('.room-eta').forEach(el => {
                  el.innerHTML = `<i class="fas fa-map-marker-alt text-info me-1"></i>${etaData.distance} km &nbsp; <i class="fas fa-car text-info me-1"></i>${etaData.eta} min away`;
                });
              }
            });
          }
        });
      } catch (e) {
        document.getElementById('roomsContainer').innerHTML =
          '<div class="text-center text-danger py-4">Error loading rooms. Please try again.</div>';
      }
    }

    function renderRooms(rooms, nights) {
      const container = document.getElementById('roomsContainer');
      if (!rooms || rooms.length === 0) {
        container.innerHTML = '<div class="text-center text-muted py-5"><i class="fas fa-bed fa-3x mb-3 d-block opacity-25"></i>No rooms available for selected dates</div>';
        return;
      }

      container.innerHTML = `<div class="row g-4" id="roomsGrid">${rooms.map(room => {
        const total = room.price * nights;
        const imgHtml = room.images && room.images.length > 0
          ? `<img src="${room.images[0]}" class="room-img" alt="${room.roomNumber}">`
          : `<div class="room-img-placeholder"><i class="fas fa-bed fa-3x text-secondary opacity-25"></i></div>`;

        return `
          <div class="col-md-6 col-lg-4 room-col" data-name="${room.roomNumber.toLowerCase()}" data-type="${room.roomType.toLowerCase()}">
            <div class="card room-card glass-card h-100 ${room.isBooked ? 'opacity-75' : ''}" 
              onclick="${room.isBooked ? '' : `openBooking('${room._id}','${room.roomNumber}','${room.roomType}',${room.price},${total},${nights})`}"
              style="cursor:${room.isBooked ? 'not-allowed' : 'pointer'}">
              <div class="position-relative">
                ${imgHtml}
                ${room.isBooked ? `
                  <div class="position-absolute top-0 end-0 m-2">
                    <span class="badge py-2 px-3" style="background:rgba(252,129,129,0.9);color:white;border-radius:20px;font-size:0.8rem;">
                      <i class="fas fa-ban me-1"></i> Booked
                    </span>
                  </div>` : ''}
              </div>
              <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h5 class="fw-bold text-white mb-0">${room.roomNumber}</h5>
                  <span class="badge" style="background:rgba(99,179,237,0.15);color:#63b3ed;border-radius:20px;">${room.roomType}</span>
                </div>
                <p class="text-secondary small mb-2">${room.description || 'Comfortable and well-furnished room'}</p>
                <div class="d-flex justify-content-between mb-2">
                  <span class="fw-bold" style="color:#68d391;font-size:1.1rem;">₹${room.price}<small class="text-secondary">/night</small></span>
                  <span class="text-secondary small"><i class="fas fa-users me-1"></i>${room.capacity} guests</span>
                </div>
                <div class="room-eta mb-3" style="font-size:0.8rem;color:#94a3b8;">
                  <i class="fas fa-spinner fa-spin me-1"></i> Calculating...
                </div>
                ${room.amenities && room.amenities.length > 0 ? `
                  <div class="d-flex flex-wrap gap-1 mb-3">
                    ${room.amenities.slice(0,3).map(a => `<span class="amenity-badge">${a}</span>`).join('')}
                  </div>` : ''}
                <div class="d-flex gap-2">
                  ${room.isBooked ? `
                    <button class="btn btn-sm flex-grow-1" disabled
                      style="background:rgba(252,129,129,0.15);color:#fc8181;border:1px solid rgba(252,129,129,0.3);border-radius:10px;">
                      <i class="fas fa-ban me-1"></i> Not Available
                    </button>` : `
                    <button class="btn btn-gradient btn-sm flex-grow-1"
                      onclick="event.stopPropagation(); openBooking('${room._id}','${room.roomNumber}','${room.roomType}',${room.price},${total},${nights})">
                      <i class="fas fa-bed me-1"></i> Book — ₹${total}
                    </button>`}
                  <button class="btn btn-glass btn-sm px-3"
                    onclick="event.stopPropagation(); window.open('https://www.google.com/maps?q=${hotelLat},${hotelLng}','_blank')"
                    title="View on Map">
                    <i class="fas fa-map-marker-alt text-info"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>`;
      }).join('')}</div>`;
    }

    function filterRooms(query) {
      const q = query.toLowerCase();
      document.querySelectorAll('.room-col').forEach(col => {
        const name = col.dataset.name || '';
        const type = col.dataset.type || '';
        col.style.display = (name.includes(q) || type.includes(q)) ? '' : 'none';
      });
    }

    function sortRooms(type, btn) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (!allRooms.length) return;
      const nights = Math.ceil((new Date(checkOut) - new Date(checkIn)) / (1000*60*60*24));
      let sorted = [...allRooms];
      if (type === 'rating') {
        const priority = { suite: 4, deluxe: 3, double: 2, single: 1 };
        sorted.sort((a, b) => (priority[b.roomType] || 0) - (priority[a.roomType] || 0));
      } else if (type === 'price-low') {
        sorted.sort((a, b) => a.price - b.price);
      } else if (type === 'price-high') {
        sorted.sort((a, b) => b.price - a.price);
      }
      // 'nearby' keeps original order (all same hotel)
      renderRooms(sorted, nights);
    }

    function applyPriceFilter() {
      const max = parseFloat(document.getElementById('maxPrice').value);
      if (!allRooms.length) return;
      const nights = Math.ceil((new Date(checkOut) - new Date(checkIn)) / (1000*60*60*24));
      const filtered = isNaN(max) ? allRooms : allRooms.filter(r => r.price <= max);
      renderRooms(filtered, nights);
    }

    function openBooking(roomId, roomNumber, roomType, pricePerNight, totalPrice, nights) {
      selectedRoom = { roomId, roomNumber, roomType, pricePerNight, totalPrice, nights };
      document.getElementById('bookingSummary').innerHTML = `
        <div class="d-flex justify-content-between mb-1">
          <span class="text-secondary">Room:</span>
          <span class="text-white fw-bold">${roomNumber} (${roomType})</span>
        </div>
        <div class="d-flex justify-content-between mb-1">
          <span class="text-secondary">Check-in:</span>
          <span class="text-white">${checkIn}</span>
        </div>
        <div class="d-flex justify-content-between mb-1">
          <span class="text-secondary">Check-out:</span>
          <span class="text-white">${checkOut}</span>
        </div>
        <div class="d-flex justify-content-between mb-1">
          <span class="text-secondary">Duration:</span>
          <span class="text-white">${nights} night${nights>1?'s':''}</span>
        </div>
        <div class="d-flex justify-content-between fw-bold mt-2 pt-2" style="border-top:1px solid rgba(255,255,255,0.1);">
          <span class="text-secondary">Total:</span>
          <span style="color:#68d391;font-size:1.1rem;">₹${totalPrice}</span>
        </div>`;
      document.getElementById('bookingMsg').innerHTML = '';
      new bootstrap.Modal(document.getElementById('bookingModal')).show();
    }

    // Load my bookings for this hotel on page load
    async function loadMyHotelBookings() {
      const container = document.getElementById('myHotelBookings');
      try {
        const res = await fetch('/api/my-bookings');
        const all = await res.json();
        // Filter for this hotel only
        const bookings = all.filter(b => b.hotelId && b.hotelId._id === hotelId);

        if (!bookings || bookings.length === 0) {
          container.innerHTML = `<div class="text-center text-secondary py-4">
            <i class="fas fa-bed fa-2x mb-2 d-block opacity-25"></i>
            <p>No bookings at this hotel yet</p>
          </div>`;
          return;
        }

        const statusColors = {
          pending: { bg: 'rgba(251,191,36,0.15)', color: '#fbbf24', border: 'rgba(251,191,36,0.3)' },
          confirmed: { bg: 'rgba(99,179,237,0.15)', color: '#63b3ed', border: 'rgba(99,179,237,0.3)' },
          'checked-in': { bg: 'rgba(104,211,145,0.15)', color: '#68d391', border: 'rgba(104,211,145,0.3)' },
          'checked-out': { bg: 'rgba(100,116,139,0.15)', color: '#94a3b8', border: 'rgba(100,116,139,0.3)' },
          cancelled: { bg: 'rgba(252,129,129,0.15)', color: '#fc8181', border: 'rgba(252,129,129,0.3)' }
        };

        container.innerHTML = bookings.map(b => {
          const sc = statusColors[b.status] || statusColors.pending;
          const checkIn = new Date(b.checkInDate).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'});
          const checkOut = new Date(b.checkOutDate).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'});
          const isActive = ['confirmed','checked-in','pending'].includes(b.status);

          return `
            <div class="glass-card p-4 mb-3" style="border-left:4px solid ${sc.color};">
              <div class="d-flex justify-content-between align-items-start">
                <div class="d-flex gap-3 align-items-start">
                  <div class="glass rounded-3 p-3 text-center" style="min-width:60px;">
                    <i class="fas fa-bed fa-lg" style="color:${sc.color};"></i>
                  </div>
                  <div>
                    <h6 class="fw-bold text-white mb-1">
                      ${b.roomId?.roomNumber || 'Room'} 
                      <span class="badge ms-1" style="background:rgba(99,179,237,0.15);color:#63b3ed;border-radius:20px;font-size:0.72rem;">
                        ${b.roomId?.roomType || ''}
                      </span>
                    </h6>
                    <p class="text-secondary small mb-1">
                      <i class="fas fa-calendar-check me-1 text-success"></i>${checkIn}
                      <i class="fas fa-arrow-right mx-2 text-secondary" style="font-size:0.7rem;"></i>
                      <i class="fas fa-calendar-times me-1 text-danger"></i>${checkOut}
                    </p>
                    <p class="text-secondary small mb-0">
                      <i class="fas fa-moon me-1"></i>${b.numberOfNights} night${b.numberOfNights > 1 ? 's' : ''}
                      &nbsp;&nbsp;
                      <span class="fw-bold" style="color:#68d391;">₹${b.totalPrice}</span>
                    </p>
                  </div>
                </div>
                <div class="text-end">
                  <span class="badge px-3 py-2 d-block mb-2" style="background:${sc.bg};color:${sc.color};border:1px solid ${sc.border};border-radius:20px;">
                    ${b.status.replace('-',' ').toUpperCase()}
                  </span>
                  <small class="text-secondary">${new Date(b.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short'})}</small>
                </div>
              </div>
            </div>`;
        }).join('');
      } catch (e) {
        container.innerHTML = '<div class="text-secondary small text-center py-3">Could not load bookings</div>';
      }
    }

    // Load on page open
    loadMyHotelBookings();

    async function confirmBooking() {
      if (!selectedRoom) return;
      const btn = document.getElementById('confirmBookBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Processing...';

      try {
        const res = await fetch('/api/bookings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            hotelId,
            roomId: selectedRoom.roomId,
            checkInDate: checkIn,
            checkOutDate: checkOut,
            guestName: document.getElementById('guestName').value,
            guestPhone: document.getElementById('guestPhone').value,
            guestEmail: document.getElementById('guestEmail').value,
            numberOfGuests: parseInt(document.getElementById('numGuests').value),
            specialRequests: document.getElementById('specialReq').value
          })
        });
        const data = await res.json();

        if (data.success) {
          document.getElementById('bookingMsg').innerHTML = `
            <div class="alert glass text-success border border-success border-opacity-25 py-3 text-center">
              <i class="fas fa-check-circle fa-2x mb-2 d-block"></i>
              <strong>Booking Confirmed!</strong><br>
              <small>You will receive a confirmation shortly.</small>
            </div>`;
          btn.innerHTML = '<i class="fas fa-check me-2"></i> Booked!';
          setTimeout(() => {
            bootstrap.Modal.getInstance(document.getElementById('bookingModal'))?.hide();
            loadMyHotelBookings(); // Refresh bookings list
            searchAvailableRooms(); // Refresh room availability
          }, 2000);
        } else {
          document.getElementById('bookingMsg').innerHTML =
            `<div class="alert glass text-danger py-2 small">${data.error || 'Booking failed'}</div>`;
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-check me-2"></i> Confirm Booking';
        }
      } catch (e) {
        document.getElementById('bookingMsg').innerHTML =
          '<div class="alert glass text-danger py-2 small">Error processing booking</div>';
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-check me-2"></i> Confirm Booking';
      }
    }
  </script>
</body>
</html>
